  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/backend.cjs",
  "scripts": {
    "build": "node esbuild.config.mjs",
