# Lint caches
.stylelintcache

# Extension output. Compiled extensions are built to public/extensions/<id>/ by
# the host Vite build from their source under `extensions/<id>/` (see
# vite-plugins/bundled-extensions.ts); that generated output is ignored.
#
# The no-build example extensions (`sculpty`, `pomodoro`) are the exception:
# they are hand-authored as a manifest.json + main.js with no build step, so
# they are checked in here directly. Re-include them explicitly.
public/extensions/*
!public/extensions/sculpty/
!public/extensions/pomodoro/

# Test coverage output
coverage/

*storybook.log
storybook-static/

# App signing secrets
config/*.p8
config/*.p12
