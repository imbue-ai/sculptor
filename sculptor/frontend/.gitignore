# Lint caches
.stylelintcache

# Plugin build output — for *compiled* plugins, source lives in `plugins/<id>/`
# and the bundle is generated by `cd plugins/<id> && npm run build` into
# public/plugins/<id>/, served at runtime. That generated output is ignored.
#
# The no-build example plugins (`sculpty`, `pomodoro`) are the exception: they
# are hand-authored as a manifest.json + main.js with no build step, so they
# are checked in here directly. Re-include them explicitly.
public/plugins/*
!public/plugins/sculpty/
!public/plugins/pomodoro/

# Test coverage output
coverage/

*storybook.log
storybook-static/

# App signing secrets
config/*.p8
config/*.p12
