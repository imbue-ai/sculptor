<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Basic entitlements for Electron app -->

    <!-- Allow outgoing network connections -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow incoming network connections (for local dev server) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow file system read access (user selected files) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow reading downloads folder -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Allow JIT compilation (required for V8 JavaScript engine) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (required for some native modules) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow dyld environment variables (needed for some native modules) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Disable library validation (allows loading of unsigned native modules) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- FOR SCULPTOR SPECIFIC NEEDS: -->

    <!-- Allow spawning child processes (for running backend binaries) -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>

    <!-- Allow camera access if needed for screen capture -->
    <!-- Uncomment if app needs camera/screen recording -->
    <!--
    <key>com.apple.security.device.camera</key>
    <true/>
    -->

    <!-- Allow microphone access if needed -->
    <!-- Uncomment if app needs microphone -->
    <!--
    <key>com.apple.security.device.microphone</key>
    <true/>
    -->

    <!-- Allow full file system access (for Git repositories anywhere) -->
    <!-- WARNING: This is broad access - consider using bookmarks instead -->
    <key>com.apple.security.files.all</key>
    <true/>

    <!-- Alternative: More restrictive file access using bookmarks -->
    <!-- Use this instead of files.all for better security -->
    <!--
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
    <key>com.apple.security.files.bookmarks.document-scope</key>
    <true/>
    -->
</dict>
</plist>
