{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./src/*"],
      // Bundled extensions import the SDK by its bare specifier; resolve it to host
      // source so `tsc` type-checks them (they're included below). Mirrors each
      // extension's own tsconfig path and the vite/import-map resolution.
      "@sculptor/extension-sdk": ["./src/extensions/sdk/index.ts"]
    },
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsc/tsbuildinfo",
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    /* Testing specific */
    "esModuleInterop": true,
    "types": ["node", "@testing-library/jest-dom"]
  },
  "include": [
    "src",
    "extensions",
    "src/globals.d.ts",
    "src/generated-types.d.ts",
    "eslint.config.ts",
    "openapi-ts.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "vitest.workspace.ts"
  ],
  "exclude": ["src/pages/tasks_deprecated/**/*", "src/quarantine/**/*", "src/electron/main.ts"]
}
