{
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,subprocess,sys; d=json.load(sys.stdin); sid=d.get('session_id'); subprocess.run(['sculpt','signal','session-id',sid]) if sid else None\" || true"
          },
          {
            "type": "command",
            "command": "sculpt signal idle || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sculpt signal busy || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sculpt signal idle || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|worker_permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "sculpt signal waiting || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "sculpt signal waiting || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sculpt signal files-changed || true"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "sculpt signal busy || true"
          }
        ]
      }
    ]
  }
}
