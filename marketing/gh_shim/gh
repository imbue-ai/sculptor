#!/usr/bin/env python3
"""Fake `gh` CLI for the demo harness: canned PR status without touching GitHub.

Sculptor's PR polling shells out to `gh api graphql` (see
sculptor/sculptor/web/pr_status.py) in exactly two shapes:

  1. a token-wide search for open PRs      (query body contains `search(`)
  2. a per-workspace repository lookup     (query body contains `repository(owner:`,
                                            branch passed as `-f branch=<name>`)

This shim answers both from a JSON fixtures file, so seeded demo workspaces
render real PR pills through the real polling pipeline. Put this script's
directory at the FRONT of the backend's PATH (marketing/seed/harness.py does
this) and point SCULPTOR_DEMO_GH_FIXTURES at the fixtures file.

Fixtures format — one entry per branch that should have a PR:

  {
    "owner": "imbue-ai",
    "branches": {
      "<head branch>": {
        "repo": "<repo name>",
        "number": 1342,
        "title": "...",
        "state": "OPEN" | "MERGED" | "CLOSED",
        "base": "main",                      // optional, default "main"
        "checks": "SUCCESS" | "FAILURE" | "PENDING" | null,   // optional
        "approvals": [{"login": "alice", "approved": true}]   // optional
      }
    }
  }

Contract notes (all load-bearing, derived from the polling code):
  - Always exit 0. A non-zero exit whose stderr smells like a rate limit puts
    the whole poller into a 60s cooldown.
  - The search response must include a healthy `rateLimit`, or the poll
    governor may defer polling entirely.
  - The search is `state:open`, so merged/closed PRs must NOT appear there;
    they are served by the repository lookup (the poller's fallback path).
  - Search nodes carry `repository.nameWithOwner` + `headRefName`; the poller
    matches them against the workspace's origin remote and current branch, so
    the fixtures' owner/repo must agree with the seeded remotes.
"""

import json
import os
import sys


def _fail_soft(payload: dict) -> None:
    """Print a well-formed empty payload; the poller treats it as 'no PRs'."""
    json.dump(payload, sys.stdout)
    sys.exit(0)


def _load_fixtures() -> dict:
    path = os.environ.get("SCULPTOR_DEMO_GH_FIXTURES", "")
    if not path or not os.path.exists(path):
        return {"owner": "imbue-ai", "branches": {}}
    with open(path) as f:
        return json.load(f)


def _flag_values(argv: list[str], flag: str) -> list[str]:
    """Collect the values of every `-f key=value` / `-F key=value` argument."""
    values = []
    for i, arg in enumerate(argv):
        if arg in ("-f", "-F") and i + 1 < len(argv):
            key, _, value = argv[i + 1].partition("=")
            if key == flag:
                values.append(value)
    return values


def _pr_node(branch: str, spec: dict, owner: str, for_search: bool) -> dict:
    base = spec.get("base", "main")
    repo = spec["repo"]
    node = {
        "number": spec["number"],
        "title": spec["title"],
        "url": f"https://github.com/{owner}/{repo}/pull/{spec['number']}",
        "state": spec["state"],
        "baseRefName": base,
    }
    if spec["state"] == "OPEN":
        node.update(
            {
                "mergeable": "MERGEABLE",
                "commits": {
                    "nodes": [{"commit": {"statusCheckRollup": {"state": spec["checks"]} if spec.get("checks") else None}}]
                },
                "latestReviews": {
                    "nodes": [
                        {"state": "APPROVED" if a.get("approved") else "CHANGES_REQUESTED", "author": {"login": a["login"]}}
                        for a in spec.get("approvals", [])
                    ]
                },
                "reviewThreads": {"nodes": []},
            }
        )
    if for_search:
        node["repository"] = {"nameWithOwner": f"{owner}/{repo}"}
        node["headRefName"] = branch
    return node


def _answer_search(fixtures: dict) -> dict:
    owner = fixtures.get("owner", "imbue-ai")
    nodes = [
        _pr_node(branch, spec, owner, for_search=True)
        for branch, spec in fixtures.get("branches", {}).items()
        if spec.get("state") == "OPEN"
    ]
    return {
        "data": {
            "search": {"pageInfo": {"hasNextPage": False, "endCursor": None}, "nodes": nodes},
            "rateLimit": {"cost": 1, "remaining": 4999, "limit": 5000, "resetAt": "2100-01-01T00:00:00Z"},
        }
    }


def _answer_repository(fixtures: dict, branch: str) -> dict:
    owner = fixtures.get("owner", "imbue-ai")
    spec = fixtures.get("branches", {}).get(branch)
    nodes = [_pr_node(branch, spec, owner, for_search=False)] if spec else []
    return {"data": {"repository": {"pullRequests": {"nodes": nodes}}}}


def main() -> None:
    argv = sys.argv[1:]
    if argv[:2] != ["api", "graphql"]:
        # Anything else (auth checks, unrelated gh use) succeeds quietly.
        sys.exit(0)

    fixtures = _load_fixtures()
    queries = _flag_values(argv, "query")
    query = queries[0] if queries else ""

    if "search(" in query:
        json.dump(_answer_search(fixtures), sys.stdout)
        sys.exit(0)

    if "repository(owner:" in query:
        branches = _flag_values(argv, "branch")
        if not branches:
            _fail_soft({"data": {"repository": {"pullRequests": {"nodes": []}}}})
        json.dump(_answer_repository(fixtures, branches[0]), sys.stdout)
        sys.exit(0)

    # Unknown graphql query shape: succeed with an empty data object rather
    # than risking an error path that reads like a rate limit.
    _fail_soft({"data": {}})


if __name__ == "__main__":
    main()
