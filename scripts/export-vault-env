#!/bin/bash
# Fetches secrets under kv/,
# and converts the key-value pairs stored inside them to shell commands.
# Also exports environment variables needed for further Vault operations.
#
# Secret paths may be suffixed by @[num] to request a specific version.
# An invocation to reproduce the fetched versions is written to stderr.
#
# Example:
#   $ ./export-vault-env shared/aws/AWS_ACCESS_KEY_ID shared/ANTHROPIC_API_KEY
#   (stdout)
#   export VAULT_ADDR=...
#   export VAULT_NAMESPACE=...
#   export AWS_ACCESS_KEY_ID=...
#   export ANTHROPIC_API_KEY=...
#   (stderr)
#   To reproduce secret versions injected:
#     ./export-vault-env shared/aws/AWS_ACCESS_KEY_ID@2 shared/ANTHROPIC_KEY@4
#
# This script can operate in the following environments:
#
# - On GitHub Actions:
#   Authenticates using GitHub's OIDC token (audience=imbue-vault).
#   Requires the env variables ACTIONS_ID_TOKEN_REQUEST_URL,
#   ACTIONS_ID_TOKEN_REQUEST_TOKEN, and VAULT_AUTH_ROLE to be set.
#   The first two are auto-injected by the runner when the calling job
#   declares `permissions: id-token: write`.
#
# - Locally:
#   Expects the user to be already logged in.
#
# On GitHub Actions, also writes the VAULT_TOKEN from
# authentication, albeit unexported, like:
#
#   VAULT_TOKEN=...
set -e
set -o pipefail
export VAULT_ADDR="https://vault-cluster-public-vault-df29b16f.9b573ab7.z1.hashicorp.cloud:8200"
export VAULT_NAMESPACE=admin
echo "export VAULT_ADDR=$VAULT_ADDR"
echo "export VAULT_NAMESPACE=$VAULT_NAMESPACE"
if test "$GITHUB_ACTIONS" = "true"; then
  # Running in GitHub Actions.
  # Request an OIDC token from the runner with audience=imbue-vault, then
  # exchange it via the jwt_github_actions backend for a Vault token.
  : "${ACTIONS_ID_TOKEN_REQUEST_URL:?ACTIONS_ID_TOKEN_REQUEST_URL is unset; the job must declare permissions: id-token: write}"
  : "${ACTIONS_ID_TOKEN_REQUEST_TOKEN:?ACTIONS_ID_TOKEN_REQUEST_TOKEN is unset; the job must declare permissions: id-token: write}"
  : "${VAULT_AUTH_ROLE:?VAULT_AUTH_ROLE is unset}"
  github_oidc_token=$(curl -sSf \
    -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" \
    "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=imbue-vault" \
    | jq -r .value)
  export VAULT_TOKEN=$(vault write -field=token auth/jwt_github_actions/login role="$VAULT_AUTH_ROLE" jwt="$github_oidc_token")
  echo "VAULT_TOKEN=$VAULT_TOKEN"
elif test -z "$VAULT_TOKEN" && ! test -f ~/.vault-token; then
  echo >&2 'Log in Vault first.'
  exit 1
fi
pinned_keys=''
for arg in "$@"; do
  # Strip any "@x" version suffix to use as the key.
  # Assigns key to $arg for unsuffixed arguments,
  # which is what we want.
  key=${arg%@*}
  if [[ "$arg" == "$key" ]]; then
    # If the two are equal,
    # that means no version suffix was stripped.
    # Passing -version= to vault is fine,
    # and requests the latest version
    requested_version=
  else
    requested_version=${arg#*@}
  fi
  env_name=${key##*/} # the last component is the environment variable name
  json=$(vault kv get -format=json -mount=secrets -version="$requested_version" "$key")
  got_version=$(printf '%s' "$json" | jq -r '.data.metadata.version' )
  value_sh_quoted=$(printf '%s' "$json" | jq -r '.data.data.value | @sh')
  printf 'export %s=%s\n' "$env_name" "$value_sh_quoted"
  pinned_keys="$pinned_keys $key@$got_version"
done

printf 'To reproduce secret versions injected:\n' >&2
printf '  %s%s\n' "$0" "$pinned_keys" >&2
