{
  "site_package_search_strategy": "all",
  "source_directories": [
    "sculptor"
  ],
  "exclude": [
    ".*/_vendor/.*",
    ".*/sculptor/frontend/node_modules/.*",
    ".*/sculptor/tests/.*",
    ".*/build/lib/.*",
    ".*/sculptor/frontend/out/.*",
    ".*/sculptor/dist/.*"
  ],
  "ignore_all_errors": [
    "sculptor/sculptor/testing",
    "sculptor/sculptor/quarantine",
    "sculptor/agent_docs"
  ]
}
